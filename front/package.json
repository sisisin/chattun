{
  "name": "chattun-front",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^22.18.0",
    "yarn": "^1.22.5"
  },
  "dependencies": {
    "babel-runtime": "6.26.0",
    "emoji-mart": "2.11.2",
    "react": "16.13.0",
    "react-dom": "16.13.0",
    "react-scripts": "5.0.1",
    "tslib": "2.6.2"
  },
  "scripts": {
    "start": "run-p start-js watch-css watch-sw",
    "start-js": "craco start",
    "start-nm": "run-p start-js-nm watch-css",
    "start-js-nm": "GENERATE_SOURCEMAP=false craco start",
    "build": "run-p build-css build-sw && run-s build-js",
    "move-assets": "rm -rf ../server/public && mkdir -p ../server && mv build ../server/public",
    "build-js": "craco build",
    "build-sw": "tsc -p ./swSrc",
    "test": "craco test",
    "eject": "craco eject",
    "lint": "vp lint",
    "lint-fix": "vp lint --fix",
    "test-all": "yarn format-check && yarn test",
    "format": "vp fmt --write && vp lint --fix",
    "format-check": "vp fmt --check && vp lint",
    "build-css": "postcss src/app/css/main.css -o public/index.css",
    "watch-css": "postcss src/app/css/main.css -o public/index.css -w",
    "watch-sw": "yarn build-sw -w",
    "g": "yarn plop feature",
    "gm": "yarn plop module"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "devDependencies": {
    "@babel/core": "7.23.2",
    "@craco/craco": "7.1.0",
    "@loadable/component": "5.12.0",
    "@types/emoji-mart": "2.11.3",
    "@types/jest": "25.1.3",
    "@types/loadable__component": "5.10.0",
    "@types/markdown-it": "0.0.9",
    "@types/node": "13.7.7",
    "@types/node-emoji": "1.8.1",
    "@types/react": "16.9.23",
    "@types/react-dom": "16.9.5",
    "@types/react-outside-click-handler": "1.3.0",
    "@types/react-router": "5.1.4",
    "@types/react-router-dom": "5.1.3",
    "@types/webpack-env": "1.18.8",
    "autoprefixer": "9.7.4",
    "babel-loader": "8.0.6",
    "buffer": "6.0.3",
    "cssnano": "4.1.10",
    "http-proxy-middleware": "2.0.1",
    "markdown-it": "10.0.0",
    "node-emoji": "1.10.0",
    "npm-run-all": "4.1.5",
    "plop": "2.5.4",
    "postcss-cli": "7.1.0",
    "postcss-custom-media": "7.0.8",
    "postcss-custom-properties": "9.1.1",
    "postcss-import": "12.0.1",
    "postcss-nested": "4.2.1",
    "postcss-nesting": "7.0.1",
    "process": "0.11.10",
    "react-hook-form": "5.1.1",
    "react-outside-click-handler": "1.3.0",
    "react-router-dom": "5.1.2",
    "rxjs": "6.5.4",
    "socket.io-client": "4.7.5",
    "typeless": "1.5.0",
    "typescript": "3.8.3",
    "vite-plus": "0.1.16"
  },
  "resolutions": {
    "@types/react": "16.9.23"
  }
}
